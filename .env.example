# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_USERNAME: The username of the channel users must join (e.g., @degenex_channel)
TELEGRAM_CHANNEL_USERNAME=
# TELEGRAM_CHANNEL_ID: The numeric ID of the channel (optional, username is usually enough)
TELEGRAM_CHANNEL_ID=
# APP_URL: The URL where the Mini App is hosted (e.g., https://my-app.run.app)
APP_URL=

# VITE_API_BASE_URL: Optional base URL for frontend API calls in production.
# Example for Vercel when backend is hosted separately:
# VITE_API_BASE_URL=https://your-backend-domain.com
VITE_API_BASE_URL=
